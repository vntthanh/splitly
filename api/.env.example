MONGODB_URI=
DATABASE_NAME=
# APP_HOST=localhost
# APP_PORT=8017
MONGODB_USER=
MONGODB_PASSWORD=

# Email Configuration (Outlook / Microsoft 365 SMTP)
ADMIN_EMAIL_ADDRESS='your-microsoft-365-mailbox@example.com'
ADMIN_EMAIL_NAME='Splitly'

# The mailbox must have Authenticated SMTP enabled by its Microsoft 365 administrator.
SMTP_HOST='smtp.office365.com'
SMTP_PORT=587
SMTP_USER='your-microsoft-365-mailbox@example.com'
SMTP_PASSWORD='your-mailbox-password-or-app-password'

ACCESS_JWT_SECRET_KEY='your_jwt_secret_key_here'
ACCESS_JWT_EXPIRES_IN='1h'


WEBSITE_DOMAIN_DEVELOPMENT='http://localhost:5173'
# Comma-separated frontend origins allowed in production, without a trailing slash.
WEBSITE_DOMAIN_PRODUCTION='https://your-frontend-domain.com'